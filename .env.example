# AIRPORT Scheduler Environment Configuration

# --- Operational Mode ---
# MODE=prototype    (Uses localized sample tracks)
# MODE=full         (Boot parameters tracing large merged dataset arrays)
RUN_MODE=prototype

# --- Python ML Inference Boundary ---
ML_INFERENCE_PORT=4000
ML_MODELS_DIR=python_ai/models/
ML_CONFIDENCE_THRESHOLD=0.70

# --- MySQL Persistence ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=anushka
MYSQL_DATABASE=airport_scheduler

# --- C++ Scheduler Logic Map ---
CPP_WS_TELEMETRY_PORT=9000
CPP_HEARTBEAT_PORT=9001
# Telemetry bound specifically at 5-10Hz operational loops natively safely
TELEMETRY_FREQUENCY_HZ=10

# --- React Frontend Gateway ---
FRONTEND_PORT=5173
REACT_APP_BFF_URL=http://localhost:4000/api
REACT_APP_BFF_WS_URL=ws://localhost:9000
